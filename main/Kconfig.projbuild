menu "SensMonitor IoT"

    choice SMONITOR_BOARD
        prompt "Hardware board"
        default SMONITOR_BOARD_LILYGO_T_SIM7000G

        config SMONITOR_BOARD_LILYGO_T_SIM7000G
            bool "LilyGO T-SIM7000G"
    endchoice

    menu "Cellular modem hardware"

        config SMONITOR_BOARD_MODEM_UART_TX_PIN
            int "Modem UART TX GPIO"
            default 27 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range 0 39

        config SMONITOR_BOARD_MODEM_UART_RX_PIN
            int "Modem UART RX GPIO"
            default 26 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range 0 39

        config SMONITOR_BOARD_MODEM_UART_RTS_PIN
            int "Modem UART RTS GPIO (-1 when unused)"
            default 25 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range -1 39

        config SMONITOR_BOARD_MODEM_UART_CTS_PIN
            int "Modem UART CTS GPIO (-1 when unused)"
            default 23 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range -1 39

        config SMONITOR_BOARD_MODEM_PWRKEY_PIN
            int "Modem PWRKEY GPIO"
            default 4 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range 0 39

        config SMONITOR_BOARD_MODEM_UART_BAUD_RATE
            int "Modem UART baud rate"
            default 9600 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range 1200 921600

        config SMONITOR_BOARD_MODEM_UART_RX_BUFFER_SIZE
            int "Modem UART RX buffer size"
            default 4096
            range 1024 16384

        config SMONITOR_BOARD_MODEM_UART_TX_BUFFER_SIZE
            int "Modem UART TX buffer size"
            default 2048
            range 512 8192

    endmenu

    config SMONITOR_MODEM_APN
        string "Mobile network APN"
        default ""
        help
            Required for a production build. It is empty by default so an
            operator profile cannot be selected accidentally.

    config SMONITOR_MODEM_USERNAME
        string "PPP authentication username"
        default ""

    config SMONITOR_MODEM_PASSWORD
        string "PPP authentication password"
        default ""

    choice SMONITOR_MODEM_AUTH
        prompt "PPP authentication"
        default SMONITOR_MODEM_AUTH_NONE

        config SMONITOR_MODEM_AUTH_NONE
            bool "None"
            help
                Matches the known-good LilyGO SIM7000G modem_console flow.

        config SMONITOR_MODEM_AUTH_PAP
            bool "PAP"
            help
                Uses the configured PPP username and password.
    endchoice

    choice SMONITOR_MODEM_NETWORK
        prompt "Preferred mobile network"
        default SMONITOR_MODEM_NETWORK_NB_IOT

        config SMONITOR_MODEM_NETWORK_AUTO
            bool "Automatic"
        config SMONITOR_MODEM_NETWORK_LTE_M
            bool "LTE-M"
        config SMONITOR_MODEM_NETWORK_NB_IOT
            bool "NB-IoT"
        config SMONITOR_MODEM_NETWORK_GPRS
            bool "GPRS"
    endchoice

    config SMONITOR_SAMPLE_INTERVAL_MS
        int "Sample interval in milliseconds"
        default 5000
        range 1000 3600000

    config SMONITOR_MODEM_CONNECT_TIMEOUT_MS
        int "PPP connection timeout in milliseconds"
        default 180000
        range 10000 600000

    menu "I2C bus"

        config SMONITOR_I2C_PORT
            int "I2C controller"
            default 0 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range 0 1

        config SMONITOR_I2C_SDA_PIN
            int "I2C SDA GPIO"
            default 21 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range 0 39

        config SMONITOR_I2C_SCL_PIN
            int "I2C SCL GPIO"
            default 22 if SMONITOR_BOARD_LILYGO_T_SIM7000G
            range 0 39

        config SMONITOR_I2C_FREQUENCY_HZ
            int "I2C bus frequency"
            default 100000
            range 10000 1000000

        config SMONITOR_I2C_INTERNAL_PULLUPS
            bool "Enable ESP32 internal pull-ups"
            default y if SMONITOR_BOARD_LILYGO_T_SIM7000G
            help
                Internal pull-ups are useful during development but external
                pull-up resistors are recommended for reliable hardware.

    endmenu

endmenu
