# Generic ESP32 + UART SIM7000 board profile
CONFIG_SMONITOR_BOARD_GENERIC_ESP32_UART=y

# Modem profile
CONFIG_SMONITOR_MODEM_PROFILE_SIM7000=y

# Modem UART wiring; change these pins for the target board
CONFIG_SMONITOR_BOARD_MODEM_UART_TX_PIN=17
CONFIG_SMONITOR_BOARD_MODEM_UART_RX_PIN=16
CONFIG_SMONITOR_BOARD_MODEM_UART_RTS_PIN=-1
CONFIG_SMONITOR_BOARD_MODEM_UART_CTS_PIN=-1
CONFIG_SMONITOR_BOARD_MODEM_UART_BAUD_RATE=9600
CONFIG_SMONITOR_BOARD_MODEM_UART_RX_BUFFER_SIZE=4096
CONFIG_SMONITOR_BOARD_MODEM_UART_TX_BUFFER_SIZE=2048

# The example assumes that the modem is powered independently
CONFIG_SMONITOR_BOARD_MODEM_POWER_EXTERNAL=y

# Disable the LilyGO-specific active GPS antenna power command
# CONFIG_SMONITOR_MODEM_GPS_ENABLE_ANTENNA_POWER is not set

# I2C bus wiring; change these pins for the target board
CONFIG_SMONITOR_I2C_PORT=0
CONFIG_SMONITOR_I2C_SDA_PIN=21
CONFIG_SMONITOR_I2C_SCL_PIN=22
# CONFIG_SMONITOR_I2C_INTERNAL_PULLUPS is not set

# No generic battery voltage divider is assumed
# CONFIG_SMONITOR_BATTERY_ENABLE is not set
