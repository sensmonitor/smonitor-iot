# LilyGO T-SIM7000G board profile
CONFIG_SMONITOR_BOARD_LILYGO_T_SIM7000G=y

# Modem profile
CONFIG_SMONITOR_MODEM_PROFILE_SIM7000=y

# Modem UART wiring
CONFIG_SMONITOR_BOARD_MODEM_UART_TX_PIN=27
CONFIG_SMONITOR_BOARD_MODEM_UART_RX_PIN=26
CONFIG_SMONITOR_BOARD_MODEM_UART_RTS_PIN=25
CONFIG_SMONITOR_BOARD_MODEM_UART_CTS_PIN=23
CONFIG_SMONITOR_BOARD_MODEM_PWRKEY_PIN=4
CONFIG_SMONITOR_BOARD_MODEM_UART_BAUD_RATE=9600
CONFIG_SMONITOR_BOARD_MODEM_UART_RX_BUFFER_SIZE=4096
CONFIG_SMONITOR_BOARD_MODEM_UART_TX_BUFFER_SIZE=2048

# I2C bus wiring
CONFIG_SMONITOR_I2C_PORT=0
CONFIG_SMONITOR_I2C_SDA_PIN=21
CONFIG_SMONITOR_I2C_SCL_PIN=22
CONFIG_SMONITOR_I2C_INTERNAL_PULLUPS=y

# Battery measurement wiring
CONFIG_SMONITOR_BATTERY_ADC_GPIO=35
CONFIG_SMONITOR_BATTERY_DIVIDER_RATIO_MILLI=2000
